# ── Backend connection ────────────────────────────────────────────────────────
# URL of the running FastAPI backend. In Docker: http://backend:8000
BACKEND_URL=http://localhost:8000

# Seconds before an API request times out (comparison can take 1-3 min)
REQUEST_TIMEOUT_SECONDS=180

# ── Log panel ─────────────────────────────────────────────────────────────────
# How often the log panel polls /logs/recent (milliseconds).
# Below ~1000 ms causes noticeable UI jitter during presentations.
LOG_STREAM_POLL_INTERVAL_MS=2000

# Maximum number of log lines kept in the frontend buffer
MAX_LOG_LINES=200

# ── Comparison paths ─────────────────────────────────────────────────────────
# Paths as seen by the BACKEND process. In Docker these are inside the container.
# For local dev, set these to absolute local paths where the backend can find them.
COMPARISON_PDF_PATH=/app/samples/FDS_PriceBook_V0.pdf
COMPARISON_DOCX_PATH=/app/samples/FDS_PriceBook_V5.docx
